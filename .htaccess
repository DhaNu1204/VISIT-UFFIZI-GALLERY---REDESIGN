# ========================================
# UFFIZI GALLERY - Apache Configuration
# Simple & Safe for Hostinger
# ========================================

RewriteEngine On

# ========================================
# 301 REDIRECTS - OLD WORDPRESS URLs
# ========================================
Redirect 301 /visit-uffizi-gallery /en
Redirect 301 /uffizi-skip-the-line-tickets /en/tickets/skip-the-line
Redirect 301 /uffizi-gallery-prices /en/tickets/prices
Redirect 301 /uffizi-tours /en/tours
Redirect 301 /uffizi-gallery-private-tour /en/tours/private-tour
Redirect 301 /uffizi-gallery-guided-tour /en/tours/guided-tour
Redirect 301 /uffizi-accademia-tour /en/tours/uffizi-accademia-tour
Redirect 301 /uffizi-gallery-tickets /en/tickets
Redirect 301 /vasari-corridor-tickets /en/vasari-corridor
Redirect 301 /uffizi-gallery-opening-hours /en/uffizi-gallery-opening-hours
Redirect 301 /how-to-get-to-the-uffizi-gallery /en/directions
Redirect 301 /the-uffizi-gallery-door-3-importent-information /en/the-uffizi-gallery-door-3-importent-information
Redirect 301 /uffizi-gallery-in-2-hours-what-to-see-and-where-to-look /en/uffizi-gallery-in-2-hours-what-to-see-and-where-to-look
Redirect 301 /the-history-of-the-uffizi-gallery /en/history
Redirect 301 /uffizi-gallery-artworks /en/artworks
Redirect 301 /uffizi-gallery-artists /en/artists
Redirect 301 /visitor-info /en/visitor-info
Redirect 301 /it/visita-galleria-uffizi /it
Redirect 301 /it/biglietti-salta-fila-uffizi /it/tickets/skip-the-line

# ========================================
# SERVE STATIC FILES
# ========================================
DirectoryIndex index.html

# Serve .html files without extension
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# ========================================
# ERROR PAGES
# ========================================
ErrorDocument 404 /404.html

# ========================================
# PERFORMANCE
# ========================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# ========================================
# SECURITY
# ========================================
Options -Indexes
AddDefaultCharset UTF-8
